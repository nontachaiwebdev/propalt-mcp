# Shared secret ChatGPT will send as: Authorization: Bearer <token>
MCP_BEARER_TOKEN=replace-with-a-long-random-string

# Propalt middlelayer API — wraps /addresses/lookup (search) and /property/{id} (fetch)
API_BASE_URL=https://api.propalt.co.uk
API_KEY=replace-with-propalt-bearer-token

# Local dev port (Railway injects PORT automatically in production)
PORT=3000
