# Public URL of this MCP server (used as OAuth issuer + in discovery metadata)
# Locally: http://localhost:3000 · On Railway: https://<your-app>.up.railway.app
PUBLIC_BASE_URL=http://localhost:3000

# Optional legacy static bearer token for ChatGPT (leave unset to force OAuth for all clients).
# If set, any request to /mcp with `Authorization: Bearer <this value>` bypasses OAuth.
MCP_BEARER_TOKEN=

# Propalt middlelayer API — wraps /addresses/lookup (search) and /property/{id} (fetch)
API_BASE_URL=https://api.propalt.co.uk
API_KEY=replace-with-propalt-bearer-token

# Local dev port (Railway injects PORT automatically in production)
PORT=3000
